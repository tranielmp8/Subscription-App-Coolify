# Database
DATABASE_URL="postgres://user:password@localhost:5432/db_name"

ORIGIN="http://localhost:5173"
CSRF_TRUSTED_ORIGINS="http://localhost:5173"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:5173"

# Better Auth
BETTER_AUTH_SECRET=""
LEGACY_OWNER_EMAIL=""

# Encryption key for stored passwords (AES-256-GCM) — DO NOT change after you have data
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Resend (https://resend.com)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="notifications@yourdomain.com"

# Protects the /api/cron/notifications endpoint
CRON_SECRET=""

# Cron service target for scheduled notifications
NOTIFICATION_CRON_URL="https://subscriptions.your-domain.com"
